@model IEnumerable<NorthwindAML.Domain.Entities.Customer>
@{
    ViewData["Title"] = "Customers";
    ViewData["Page"] = "Customers";
}

<div class="form-card">
    <div class="form-title">Add New Customer</div>
    @if (TempData["Message"] != null)
    {
        <div class="alert @(TempData["IsError"] != null && (bool)TempData["IsError"] ? "alert-danger" : "alert-success")" style="display:block">
            @TempData["Message"]
        </div>
    }
    <form asp-action="AddCustomer" method="post">
        <div class="form-row">
            <div class="form-group">
                <label>Customer ID</label>
                <input name="CustomerID" placeholder="e.g. NEWCO" maxlength="5" />
            </div>
            <div class="form-group">
                <label>Company Name</label>
                <input name="CompanyName" placeholder="Company name" />
            </div>
            <div class="form-group">
                <label>Contact Name</label>
                <input name="ContactName" placeholder="Contact person" />
            </div>
            <div class="form-group">
                <label>Country</label>
                <input name="Country" placeholder="e.g. Germany" />
            </div>
            <div class="form-group" style="flex:0">
                <label>&nbsp;</label>
                <button type="submit" class="btn btn-accent">+ Add</button>
            </div>
        </div>
    </form>
</div>

<div class="table-container">
    <div class="table-header">
        <div class="table-title">All Customers</div>
        <span class="badge badge-accent">@Model.Count() total</span>
    </div>
    <table>
        <thead>
            <tr>
                <th>ID</th>
                <th>Company Name</th>
                <th>Contact</th>
                <th>Country</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in Model)
            {
                <tr>
                    <td style="font-family:var(--font-mono);color:var(--accent)">@c.CustomerID</td>
                    <td>@c.CompanyName</td>
                    <td style="color:var(--text-muted)">@c.ContactName</td>
                    <td>@c.Country</td>
                    <td>
                        <form asp-action="DeleteCustomer" method="post" style="display:inline">
                            <input type="hidden" name="id" value="@c.CustomerID" />
                            <button type="submit" class="btn btn-danger" style="padding:4px 12px;font-size:11px">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>