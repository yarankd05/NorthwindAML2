<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — NorthwindAML</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">
        <aside class="sidebar">
            <div class="sidebar-logo">
                <span class="logo-hex">⬡</span>
                <div>
                    <div class="logo-title">NW<span class="logo-accent">AML</span></div>
                    <div class="logo-sub">Compliance Monitor</div>
                </div>
            </div>
            <nav class="sidebar-nav">
                <a href="/Home/Index" class="nav-item @(ViewData["Page"]?.ToString() == "Dashboard" ? "active" : "")">
                    <span class="nav-icon">▣</span>
                    <span>Dashboard</span>
                </a>
                <a href="/Home/Customers" class="nav-item @(ViewData["Page"]?.ToString() == "Customers" ? "active" : "")">
                    <span class="nav-icon">◈</span>
                    <span>Customers</span>
                </a>
                <a href="/Home/Watchlist" class="nav-item @(ViewData["Page"]?.ToString() == "Watchlist" ? "active" : "")">
                    <span class="nav-icon">⚑</span>
                    <span>Watchlist</span>
                </a>
                <a href="/Home/TransactionMonitor" class="nav-item @(ViewData["Page"]?.ToString() == "Monitor" ? "active" : "")">
                    <span class="nav-icon">◎</span>
                    <span>TX Monitor</span>
                </a>
                <a href="/Home/RiskScores" class="nav-item @(ViewData["Page"]?.ToString() == "Risk" ? "active" : "")">
                    <span class="nav-icon">◆</span>
                    <span>Risk Scores</span>
                </a>
                <a href="/Home/SAR" class="nav-item @(ViewData["Page"]?.ToString() == "SAR" ? "active" : "")">
                    <span class="nav-icon">⊛</span>
                    <span>SAR Records</span>
                </a>
            </nav>
            <div class="sidebar-bottom">
                <div class="sidebar-status">
                    <div class="status-dot"></div>
                    <span>System Online</span>
                </div>
                <a href="/Auth/Logout" class="logout-btn">⏻ Logout</a>
            </div>
        </aside>
        <main class="main-content">
            <header class="top-bar">
                <h1 class="page-title">@ViewData["Title"]</h1>
                <div class="top-bar-right">
                    <span class="user-badge">@User.Identity?.Name</span>
                    <span class="sys-time" id="sysTime"></span>
                </div>
            </header>
            <div class="content-area">
                @RenderBody()
            </div>
        </main>
    </div>
    <script>
        function updateTime() {
            document.getElementById('sysTime').textContent = new Date().toLocaleTimeString('en-GB', {hour12: false});
        }
        setInterval(updateTime, 1000);
        updateTime();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>